<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AssetBankPlugin"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <Style TargetType="{x:Type local:AntStateAssetEditor}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:AntStateAssetEditor}">
                    <Grid Background="{StaticResource WindowBackground}" DataContext="{RelativeSource TemplatedParent}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource WindowBackground}" Margin="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Source="/FrostyEditor;component/Images/Filter.png" Width="14" Margin="4,0" Opacity="0.5"/>

                                    <ctrl:FrostyWatermarkTextBox x:Name="PART_SearchBox" Grid.Column="1" Margin="2" 
                                        VerticalContentAlignment="Center"
                                        WatermarkText="Search assets by name or GUID..."
                                        Background="{StaticResource WindowBackground}"
                                        Foreground="{StaticResource FontColor}"
                                        BorderThickness="0"/>

                                    <!-- Add Reference Button -->
                                    <Button x:Name="PART_AddRefButton" Grid.Column="2" 
                                            Margin="4,2" Padding="8,2"
                                            Height="24"
                                            Background="{StaticResource ControlBackground}"
                                            BorderThickness="1" BorderBrush="#505050"
                                            ToolTip="Manually load external reference banks into cache">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/FrostyEditor;component/Images/Add.png" Width="14" Height="14" Margin="0,0,4,0"/>
                                            <TextBlock Text="Add References" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Multi Select ToggleButton -->
                                    <ToggleButton x:Name="PART_BulkToggle" Grid.Column="3" 
                                                  Margin="4,2" Padding="8,0"
                                                  Height="24"
                                                  Foreground="White" 
                                                  VerticalAlignment="Center"
                                                  Background="{StaticResource ControlBackground}"
                                                  BorderThickness="1" BorderBrush="#505050">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                      IsHitTestVisible="False"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                                            <TextBlock Text="Multi Select" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <!-- Export button -->
                                    <Button x:Name="PART_ExportBulkButton" Grid.Column="4" 
                                            Margin="4,2,8,2" Padding="4,2"
                                            Height="24"
                                            Background="{StaticResource ControlBackground}"
                                            BorderThickness="1" BorderBrush="#505050"
                                            IsEnabled="{Binding IsExportEnabled, RelativeSource={RelativeSource TemplatedParent}}"
                                            ToolTip="Export selected animation(s)">
                                        <Image Source="/FrostyEditor;component/Images/Export.png" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <TreeView x:Name="PART_AssetTreeView" Grid.Row="1" 
                                      Background="{StaticResource ListBackground}" 
                                      BorderThickness="0"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <TreeView.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#404040"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#404040"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>

                                    <!-- Group Template -->
                                    <HierarchicalDataTemplate DataType="{x:Type local:AntTypeGroup}" ItemsSource="{Binding Assets}">
                                        <Border Padding="0,2,0,0" Margin="0,2">
                                            <DockPanel>
                                                <TextBlock Text="{Binding TypeName}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" Foreground="#909090"/>
                                            </DockPanel>
                                        </Border>
                                    </HierarchicalDataTemplate>

                                    <!-- Asset Template (Copy GUID + Export) -->
                                    <HierarchicalDataTemplate DataType="{x:Type local:AntAssetViewModel}" ItemsSource="{Binding Properties}">
                                        <Grid Margin="0,2" Background="Transparent">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy GUID" Command="{Binding CopyGuidCommand}">
                                                        <MenuItem.Icon>
                                                            <Image Source="/FrostyCore;component/Images/Copy.png" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Export Animation" 
                                                              Command="{Binding ExportCommand}" 
                                                              Visibility="{Binding ExportVisibility}">
                                                        <MenuItem.Icon>
                                                            <Image Source="/FrostyEditor;component/Images/Export.png" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="350"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelectedForExport}" 
                                                      Visibility="{Binding CheckboxVisibility}" 
                                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Id}" Foreground="#909090" VerticalAlignment="Center"/>
                                        </Grid>
                                    </HierarchicalDataTemplate>

                                    <!-- Property Template (Copy Value) -->
                                    <HierarchicalDataTemplate DataType="{x:Type local:AntPropertyViewModel}" ItemsSource="{Binding Children}">
                                        <Grid Margin="0,1" Background="Transparent">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy Value" Command="{Binding CopyValueCommand}">
                                                        <MenuItem.Icon>
                                                            <Image Source="/FrostyCore;component/Images/Copy.png" Width="14" Height="14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" 
                                                       ToolTip="{Binding TypeStr}"
                                                       ToolTipService.Placement="Mouse"
                                                       ToolTipService.HorizontalOffset="18"
                                                       ToolTipService.VerticalOffset="-20"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ValueStr}" Foreground="White" TextWrapping="Wrap"/>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>

                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource baseTreeViewItemStyle}">
                                        <Setter Property="IsExpanded" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Grid>

                        <Border x:Name="PART_LoadingOverlay" Background="{StaticResource WindowBackground}" Panel.ZIndex="10" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ctrl:FrostySpinner Width="60" Height="60" />
                                <TextBlock x:Name="PART_LoadingText" Text="Parsing AntState Bank..." Foreground="White" FontSize="14" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
